{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wicked-jl.local/schemas/reference-parity-summary.schema.json",
  "title": "Wicked reference parity summary artifact",
  "type": "object",
  "required": ["schema_version", "total", "by_status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "total": {
